# LearnSync AI v1.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# GENERAL SETTINGS
# ============================================
NODE_ENV=production
DOMAIN=localhost
APP_VERSION=1.0.0

# ============================================
# DATABASE (MongoDB)
# ============================================
MONGODB_URI=mongodb://mongo:27017/learnsync
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_secure_password

# ============================================
# REDIS (Cache & Sessions)
# ============================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate secure keys: openssl rand -base64 64
JWT_SECRET=your_super_secure_jwt_secret_key_min_64_chars_long_here
JWT_REFRESH_SECRET=your_super_secure_refresh_token_secret_key_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============================================
# EMAIL SERVICE (for notifications)
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=LearnSync AI <noreply@learnsync.ai>

# ============================================
# AI SERVICE
# ============================================
AI_SERVICE_URL=http://ai-service:8000
MODEL_RETRAIN_CRON=0 2 * * 0
ENABLE_MODEL_EXPLAINABILITY=true

# ============================================
# MONITORING
# ============================================
GRAFANA_USER=admin
GRAFANA_PASS=admin
ENABLE_METRICS=true

# ============================================
# CLOUD STORAGE (optional - for file uploads)
# ============================================
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1