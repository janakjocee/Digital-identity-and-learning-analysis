{
  "name": "learnsync-ai-backend",
  "version": "1.0.0",
  "description": "AI-Powered Learning Analytics Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "seed:accounts": "node ../app/server/src/utils/seedAccounts.js",
    "seed:curriculum": "node ../app/server/src/utils/seedCurriculum.js",
    "seed:all": "npm run seed:accounts && npm run seed:curriculum",
    "verify:accounts": "node ../app/server/src/utils/verifyAccounts.js",
    "verify:production": "node ../app/server/src/utils/verifyAccounts.js https://digital-identity-and-learning-analy.vercel.app/api"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "education",
    "ai",
    "learning",
    "analytics",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Janak Raj Joshi",
  "license": "MIT"
}
