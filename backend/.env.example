# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/learnsync_ai

# JWT Configuration (REQUIRED - must be long random strings)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_REFRESH_EXPIRE=30d

# CORS Configuration
# For production on Render, set one of these:
#   CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com  (comma-separated)
#   FRONTEND_URL=https://your-app.vercel.app  (single URL)
# If neither is set in production, all origins are allowed (not recommended for production).
FRONTEND_URL=http://localhost:5173

# AI Microservice
AI_SERVICE_URL=http://localhost:8000

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100